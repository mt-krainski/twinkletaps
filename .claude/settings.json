{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-allowlist.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/restrict-write-to-project.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(git status)",
      "Bash(git status -u)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git fetch origin *)",
      "Bash(git pull)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git merge-base *)",
      "Bash(git rev-parse HEAD)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(mkdir *)",
      "Bash(npm run *)",
      "Bash(npm install)",
      "Bash(npm view *)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(agent-utils/scripts/run-with-tail.sh *)",
      "Bash(agent-utils/scripts/find-grep.sh *)",
      "Bash(agent-utils *)",
      "Bash(jira-utils *)",
      "Bash(git merge origin/main)",
      "Bash(grep:*)",
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Read",
      "Edit",
      "Write",
      "mcp__*",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm run supr:*)",
      "Write(.claude/**)",
      "Read(.env*)",
      "Bash(cat .env*)",
      "Bash(grep * .env*)"
    ]
  }
}
